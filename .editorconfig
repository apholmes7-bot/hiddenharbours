# Hidden Harbours — C# / Unity code style. Keeps every agent's output formatted
# identically, which makes diffs small and merges clean.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.cs]
# Naming: PascalCase types/methods/properties, camelCase locals/params,
# _camelCase private fields, ALL_CAPS consts. (Enforced by review, see CLAUDE.md.)
dotnet_sort_system_directives_first = true
csharp_new_line_before_open_brace = all
csharp_prefer_braces = true:warning
dotnet_style_qualification_for_field = false:suggestion
dotnet_style_readonly_field = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_expression_bodied_methods = false:none

[*.{json,yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
